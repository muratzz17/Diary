{
  "Logging": {
    "LogLevel": {
      // Uygulama genelindeki günlükleme seviyesi (Bilgilendirme ve üzeri seviyeleri kaydeder)
      "Default": "Information",
      // Microsoft altyapısından gelen mesajlar için sadece 'Uyarı' ve üzerini gösterir
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Uygulamaya hangi domainlerden erişilebileceğini belirler ("*" her yerden erişime izin verir)
  "AllowedHosts": "*",

  "ConnectionStrings": {
    // Veritabanı bağlantı bilgilerinin saklandığı ana bölüm
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=DiaryApp;Trusted_Connection=True;TrustedServerCertificate=True"
  }
}