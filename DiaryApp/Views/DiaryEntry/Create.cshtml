@* Yeni oluşturulacak günlük girişini temsil eden boş bir model yapısı tanımlıyoruz *@
@model DiaryApp.Models.DiaryEntry

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                @* Kartın başlık alanı (Mavi temalı tasarım) *@
                <div class="card-header bg-primary text-white">
                    <h2>Create Diary Entry</h2>
                </div>
                <div class="card-body">
                    @* Form verileri POST metoduyla Controller'daki Create aksiyonuna gönderir *@
                    <form asp-action="Create" method="post">

                        @* Modeldeki tüm doğrulama hatalarını (Boş bırakılamaz, karakter sınırı vb.) toplu halde gösterir *@
                        <div asp-validation-summary="All" class="text-danger"></div>

                        @* Başlık giriş alanı: Kullanıcıdan günlüğün başlığını alır *@
                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label">Title </label>
                            <input asp-for="Title" class="form-control" placeholder="Enter a title" />
                        </div>

                        @* İçerik giriş alanı: Günlük metninin yazılacağı yer *@
                        <div class="form-group mb-3">
                            <label asp-for="Content" class="form-label">Content </label>
                            <input asp-for="Content" row="5" class="form-control" placeholder="Enter a Content" />
                        </div>

                        @* Tarih giriş alanı: Takvim aracılığıyla tarih seçilmesini sağlar *@
                        <div class="form-group mb-3">
                            <label asp-for="Created" class="form-label">Date </label>
                            <input asp-for="Created" class="form-control" type="date" />
                        </div>

                        @* İşlem Butonları *@
                        <div class="d-flex justify-content-between">
                            @* Formdaki verileri paketleyip Controller'a gönderen buton *@
                            <button type="submit" class="btn btn-primary">Create</button>

                            @* İşlemden vazgeçip ana listeye geri dönmeyi sağlayan buton *@
                            <a asp-controller="DiaryEntry" asp-action="Index" class="btn btn-danger">Cancel </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* Client-side validation (İstemci tarafı doğrulama): *@
    @* Sayfa sunucuya gitmeden önce tarayıcıda hızlı hata kontrolü yapılmasını sağlar *@
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</div>